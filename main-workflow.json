    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) return [];\n\nlet totalConsumption = 0;\nfor (const item of items) {\n    totalConsumption += parseFloat(item.json.media_consumo);\n}\nconst globalAvg = totalConsumption / items.length;\nconst upperThreshold = globalAvg * 1.5; // 50% acima da média\nconst lowerThreshold = globalAvg * 0.5; // 50% abaixo da média\n\nconst processedData = items.map(item => {\n    const media = parseFloat(item.json.media_consumo);\n    let status = 'normal';\n    \n    if (media > upperThreshold || media < lowerThreshold) {\n        status = 'outlier';\n    }\n\n    return {\n        \"Nome do cliente\": item.json['Nome do cliente'],\n        \"Média de consumo\": Number(media.toFixed(4)),\n        \"Status\": status\n    };\n});\n\nreturn [{ json: { relatorio_dados: processedData } }];"
      },
