        "query": "SELECT \n    c.name AS \"Nome do cliente\",\n    AVG(er.kwh_value) AS media_consumo\nFROM customers c\nJOIN contracts ct ON c.id = ct.customer_id\nJOIN energy_readings er ON ct.id = er.contract_id\nWHERE ct.is_active = TRUE\nGROUP BY c.id, c.name;",
